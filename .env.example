# ESA Incentive Pipeline Configuration

# Horaro schedule slugs (comma-separated)
HORARO_ORG=esa
HORARO_SCHEDULES=2026-summer1,2026-summer2
# Optional: extra Horaro slugs to scan for runner past-ESA appearances
# (defaults: every event under horaro.net/esa EXCEPT the current slugs above).
# Set this to a comma-separated list to limit the scan, e.g. for a faster batch.
HORARO_PAST_SCHEDULES=

# Oengus marathon ID
OENGUS_MARATHON_ID=ESA-Sum26

# Oengus session cookie (for moderator access to submission answers)
# Copy from browser DevTools > Application > Cookies after logging in
OENGUS_COOKIE=

# Output file path (CSV or XLSX)
OUTPUT_FILE=output/incentive_plan.xlsx
OUTPUT_FORMAT=xlsx

# News ticker
# Comma-separated RSS/Atom feed URLs for general gaming news.
NEWS_RSS_FEEDS=https://www.theverge.com/games/rss/index.xml,https://www.gamespot.com/feeds/news
# Number of most-recently-verified speedrun.com runs to pull per scheduled game.
NEWS_SPEEDRUN_TOP_N=3
# Max items to keep per RSS feed per refresh.
NEWS_RSS_MAX_PER_FEED=10
# Retention cap: total news items kept in the DB (older items pruned).
NEWS_MAX_ITEMS=100

# Web search cache (for evaluation harness)
# Should point to a durable location the operator backs up (e.g. synced to
# S3/Backblaze). The software works without this file -- any missing entries
# are reported as "not yet web-searched" rather than blocking.
# Default: tests/websearch_cache.json
WEBSEARCH_CACHE=tests/websearch_cache.json

# ─── Tiltify push (browser automation, not the API) ────────────────────
# Tiltify V5 API has no write endpoints for rewards/polls/targets, so the
# push is done via Playwright dashboard automation. Install with:
#   pip install playwright && playwright install chromium
#
# Campaign UUID — copy from the dashboard URL after /campaigns/<uuid>/
TILTIFY_CAMPAIGN_ID=
# Path to a Playwright storage_state JSON (created by --tiltify-login).
# Tiltify session cookies rotate on each login; re-run --tiltify-login
# to refresh. Default: output/tiltify_session.json
TILTIFY_SESSION_PATH=output/tiltify_session.json
# Fallback when no session file exists: paste the raw 'Cookie:' header
# from DevTools > Network > app.tiltify.com. Treats this like a password.
TILTIFY_COOKIE=
# Chromium mode for --tiltify-push (true|false). Set false to watch the
# clicks during debugging.
TILTIFY_HEADLESS=true
# Dollars per minute added: when an incentive_estimate is "5" minutes, the
# Tiltify reward minimum is set to INCENTIVE_DOLLAR_PER_MIN × 5 (default $25).
INCENTIVE_DOLLAR_PER_MIN=5

# Web viewer — shared password for host access
SHARED_PASSWORD=
SESSION_SECRET=
CORS_ORIGIN=http://localhost:3000

# Data layer (Phase 2)
# REPO_TYPE=xlsx  → read directly from incentive_plan.xlsx (Phase 1, read-only)
# REPO_TYPE=sqlite → read from output/esa.db (Phase 2+, supports editing)
REPO_TYPE=sqlite
DB_PATH=output/esa.db

# Admin operations (Phase 2)
ADMIN_PASSWORD=
SNAPSHOT_KEEP=10

# ─── S3 backup (Backblaze B2) ──────────────────────────────────────────
# Backup service runs in a sidecar container via docker-compose.
# Backups are taken hourly (cron) and promoted to daily once per day.
# Hourly and daily each keep 5 snapshots; older ones are pruned.
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=codescales-esa-backups
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
BACKUP_CRON=0 * * * *
KEEP_HOURLY=5
KEEP_DAILY=5
